    "title": "[:ua]11 українських ЗВО увійшли до світового рейтингу найкращих університетів[:ru]11 украинских ВУЗов вошли в мировой рейтинг лучших университетов[:]",
    "text": "\\u0412\\u043f\\u0435\\u0440\\u0448\\u0435 \\u0431\\u0440\\u0438\\u0442\\u0430\\u043d\\u0441\\u044c\\u043a\\u0438\\u0439 \\u0436\\u0443\\u0440\\u043d\\u0430\\u043b Times Higher Education \\u043f\\u0440\\u0435\\u0434\\u0441\\u0442\\u0430\\u0432\\u0438\\u0432 Interdisciplinary Science Rankings 2025, \\u0434\\u0435 \\u043e\\u0446\\u0456\\u043d\\u0438\\u0432 \\u0432\\u043d\\u0435\\u0441\\u043e\\u043a \\u0443\\u043d\\u0456\\u0432\\u0435\\u0440\\u0441\\u0438\\u0442\\u0435\\u0442\\u0456\\u0432 \\u0443 \\u043c\\u0456\\u0436\\u0434\\u0438\\u0441\\u0446\\u0438\\u043f\\u043b\\u0456\\u043d\\u0430\\u0440\\u043d\\u0443 \\u043d\\u0430\\u0443\\u043a\\u0443.\\xa0\\u0414\\u043e \\u0440\\u0435\\u0439\\u0442\\u0438\\u043d\\u0433\\u0443 \\u043f\\u043e\\u0442\\u0440\\u0430\\u043f\\u0438\\u043b\\u0438 749 \\u0443\\u043d\\u0456\\u0432\\u0435\\u0440\\u0441\\u0438\\u0442\\u0435\\u0442\\u0456\\u0432 \\u0456\\u0437 92 \\u043a\\u0440\\u0430\\u0457\\u043d, \\u0441\\u0435\\u0440\\u0435\\u0434 \\u043d\\u0438\\u0445 \\u2014 11 \\u0443\\u043a\\u0440\\u0430\\u0457\\u043d\\u0441\\u044c\\u043a\\u0438\\u0445 \\u0437\\u0430\\u043a\\u043b\\u0430\\u0434\\u0456\\u0432 \\u0432\\u0438\\u0449\\u043e\\u0457 \\u043e\\u0441\\u0432\\u0456\\u0442\\u0438. \\n\\u041f\\u0440\\u043e \\u0446\\u0435 \\xa0 \\u043f\\u043e\\u0432\\u0456\\u0434\\u043e\\u043c\\u043b\\u044f\\u0454\\u0442\\u044c\\u0441\\u044f \\xa0 \\u043d\\u0430 \\u0441\\u0430\\u0439\\u0442\\u0456 \\u0436\\u0443\\u0440\\u043d\\u0430\\u043b\\u0443, \\u043f\\u0438\\u0448\\u0435 \\u0420\\u0443\\u0431\\u0440\\u0438\\u043a\\u0430 .\n\\n \\u0422\\u0430\\u043a, \\u0441\\u0435\\u0440\\u0435\\u0434 \\u0443\\u043a\\u0440\\u0430\\u0457\\u043d\\u0441\\u044c\\u043a\\u0438\\u0445 \\u0443\\u043d\\u0456\\u0432\\u0435\\u0440\\u0441\\u0438\\u0442\\u0435\\u0442\\u0456\\u0432 \\u043b\\u0456\\u0434\\u0438\\u0440\\u0443\\u044e\\u0442\\u044c:\n\\n \\n \\u0421\\u0443\\u043c\\u0441\\u044c\\u043a\\u0438\\u0439 \\u0434\\u0435\\u0440\\u0436\\u0430\\u0432\\u043d\\u0438\\u0439 \\u0443\\u043d\\u0456\\u0432\\u0435\\u0440\\u0441\\u0438\\u0442\\u0435\\u0442 \\u043f\\u043e\\u0441\\u0456\\u0432 \\u043d\\u0430\\u0439\\u0432\\u0438\\u0449\\u0435 \\u043c\\u0456\\u0441\\u0446\\u0435 \\u0441\\u0435\\u0440\\u0435\\u0434 \\u0443\\u043a\\u0440\\u0430\\u0457\\u043d\\u0441\\u044c\\u043a\\u0438\\u0445 \\u0437\\u0430\\u043a\\u043b\\u0430\\u0434\\u0456\\u0432 \\u2014 251-300, \\u0456\\u0437 \\u0437\\u0430\\u0433\\u0430\\u043b\\u044c\\u043d\\u0438\\u043c \\u0431\\u0430\\u043b\\u043e\\u043c 39.8\\u201342.5. \\n \\u041a\\u0438\\u0457\\u0432\\u0441\\u044c\\u043a\\u0438\\u0439 \\u043f\\u043e\\u043b\\u0456\\u0442\\u0435\\u0445\\u043d\\u0456\\u0447\\u043d\\u0438\\u0439 \\u0456\\u043d\\u0441\\u0442\\u0438\\u0442\\u0443\\u0442 \\u0456\\u043c\\u0435\\u043d\\u0456 \\u0406\\u0433\\u043e\\u0440\\u044f \\u0421\\u0456\\u043a\\u043e\\u0440\\u0441\\u044c\\u043a\\u043e\\u0433\\u043e \\u0442\\u0430 \\u041a\\u0438\\u0457\\u0432\\u0441\\u044c\\u043a\\u0438\\u0439 \\u043d\\u0430\\u0446\\u0456\\u043e\\u043d\\u0430\\u043b\\u044c\\u043d\\u0438\\u0439 \\u0443\\u043d\\u0456\\u0432\\u0435\\u0440\\u0441\\u0438\\u0442\\u0435\\u0442 \\u0456\\u043c\\u0435\\u043d\\u0456 \\u0422\\u0430\\u0440\\u0430\\u0441\\u0430 \\u0428\\u0435\\u0432\\u0447\\u0435\\u043d\\u043a \\u0430 \\u0440\\u043e\\u0437\\u0434\\u0456\\u043b\\u0438\\u043b\\u0438 \\u043f\\u043e\\u0437\\u0438\\u0446\\u0456\\u044e 401-500 (\\u0431\\u0430\\u043b 30.0\\u201334.7). \\n \\u041b\\u044c\\u0432\\u0456\\u0432\\u0441\\u044c\\u043a\\u0438\\u0439 \\u043d\\u0430\\u0446\\u0456\\u043e\\u043d\\u0430\\u043b\\u044c\\u043d\\u0438\\u0439 \\u0443\\u043d\\u0456\\u0432\\u0435\\u0440\\u0441\\u0438\\u0442\\u0435\\u0442 \\u0456\\u043c\\u0435\\u043d\\u0456 \\u0406\\u0432\\u0430\\u043d\\u0430 \\u0424\\u0440\\u0430\\u043d\\u043a\\u0430 \\u0442\\u0430 \\u0425\\u0430\\u0440\\u043a\\u0456\\u0432\\u0441\\u044c\\u043a\\u0438\\u0439 \\u043f\\u043e\\u043b\\u0456\\u0442\\u0435\\u0445\\u043d\\u0456\\u0447\\u043d\\u0438\\u0439 \\u0456\\u043d\\u0441\\u0442\\u0438\\u0442\\u0443\\u0442 \\u043e\\u043f\\u0438\\u043d\\u0438\\u043b\\u0438\\u0441\\u044f \\u0443 \\u043a\\u0430\\u0442\\u0435\\u0433\\u043e\\u0440\\u0456\\u0457 501-600 (\\u0431\\u0430\\u043b 25.4\\u201329.9). \\n \\n \\u0414\\u043e \\u043a\\u0430\\u0442\\u0435\\u0433\\u043e\\u0440\\u0456\\u0457 600+ \\u0443\\u0432\\u0456\\u0439\\u0448\\u043b\\u0438:\n\\n \\n \\u0425\\u0430\\u0440\\u043a\\u0456\\u0432\\u0441\\u044c\\u043a\\u0438\\u0439 \\u043d\\u0430\\u0446\\u0456\\u043e\\u043d\\u0430\\u043b\\u044c\\u043d\\u0438\\u0439 \\u0443\\u043d\\u0456\\u0432\\u0435\\u0440\\u0441\\u0438\\u0442\\u0435\\u0442 \\u0440\\u0430\\u0434\\u0456\\u043e\\u0435\\u043b\\u0435\\u043a\\u0442\\u0440\\u043e\\u043d\\u0456\\u043a\\u0438; \\n \\u041d\\u0430\\u0446\\u0456\\u043e\\u043d\\u0430\\u043b\\u044c\\u043d\\u0438\\u0439 \\u0443\\u043d\\u0456\\u0432\\u0435\\u0440\\u0441\\u0438\\u0442\\u0435\\u0442 \\xab\\u041b\\u044c\\u0432\\u0456\\u0432\\u0441\\u044c\\u043a\\u0430 \\u043f\\u043e\\u043b\\u0456\\u0442\\u0435\\u0445\\u043d\\u0456\\u043a\\u0430\\xbb; \\n \\u041d\\u0430\\u0446\\u0456\\u043e\\u043d\\u0430\\u043b\\u044c\\u043d\\u0438\\u0439 \\u0443\\u043d\\u0456\\u0432\\u0435\\u0440\\u0441\\u0438\\u0442\\u0435\\u0442 \\u0445\\u0430\\u0440\\u0447\\u043e\\u0432\\u0438\\u0445 \\u0442\\u0435\\u0445\\u043d\\u043e\\u043b\\u043e\\u0433\\u0456\\u0439; \\n \\u0423\\u0436\\u0433\\u043e\\u0440\\u043e\\u0434\\u0441\\u044c\\u043a\\u0438\\u0439 \\u043d\\u0430\\u0446\\u0456\\u043e\\u043d\\u0430\\u043b\\u044c\\u043d\\u0438\\u0439 \\u0443\\u043d\\u0456\\u0432\\u0435\\u0440\\u0441\\u0438\\u0442\\u0435\\u0442; \\n \\u041f\\u0440\\u0438\\u043a\\u0430\\u0440\\u043f\\u0430\\u0442\\u0441\\u044c\\u043a\\u0438\\u0439 \\u043d\\u0430\\u0446\\u0456\\u043e\\u043d\\u0430\\u043b\\u044c\\u043d\\u0438\\u0439 \\u0443\\u043d\\u0456\\u0432\\u0435\\u0440\\u0441\\u0438\\u0442\\u0435\\u0442 \\u0456\\u043c\\u0435\\u043d\\u0456 \\u0412\\u0430\\u0441\\u0438\\u043b\\u044f \\u0421\\u0442\\u0435\\u0444\\u0430\\u043d\\u0438\\u043a\\u0430; \\n \\u0425\\u0430\\u0440\\u043a\\u0456\\u0432\\u0441\\u044c\\u043a\\u0438\\u0439 \\u043d\\u0430\\u0446\\u0456\\u043e\\u043d\\u0430\\u043b\\u044c\\u043d\\u0438\\u0439 \\u0443\\u043d\\u0456\\u0432\\u0435\\u0440\\u0441\\u0438\\u0442\\u0435\\u0442 \\u0456\\u043c\\u0435\\u043d\\u0456 \\u0412. \\u041d. \\u041a\\u0430\\u0440\\u0430\\u0437\\u0456\\u043d\\u0430. \\n \\n\\u0412\\u0430\\u0440\\u0442\\u043e \\u0437\\u0430\\u0437\\u043d\\u0430\\u0447\\u0438\\u0442\\u0438, \\u0449\\u043e \\u0440\\u0435\\u0439\\u0442\\u0438\\u043d\\u0433 \\u0431\\u0430\\u0437\\u0443\\u0454\\u0442\\u044c\\u0441\\u044f \\u043d\\u0430 11 \\u043f\\u043e\\u043a\\u0430\\u0437\\u043d\\u0438\\u043a\\u0430\\u0445 \\u0435\\u0444\\u0435\\u043a\\u0442\\u0438\\u0432\\u043d\\u043e\\u0441\\u0442\\u0456, \\u044f\\u043a\\u0456 \\u043e\\u0446\\u0456\\u043d\\u044e\\u044e\\u0442\\u044c \\xa0 \\u0432\\u0445\\u0456\\u0434\\u043d\\u0456 \\u0440\\u0435\\u0441\\u0443\\u0440\\u0441\\u0438 \\xa0 (\\u0444\\u0456\\u043d\\u0430\\u043d\\u0441\\u0443\\u0432\\u0430\\u043d\\u043d\\u044f), \\xa0 \\u043f\\u0440\\u043e\\u0446\\u0435\\u0441\\u0438 \\xa0 (\\u043c\\u0430\\u0442\\u0435\\u0440\\u0456\\u0430\\u043b\\u044c\\u043d\\u0430 \\u0431\\u0430\\u0437\\u0430, \\u0430\\u0434\\u043c\\u0456\\u043d\\u0456\\u0441\\u0442\\u0440\\u0430\\u0442\\u0438\\u0432\\u043d\\u0430 \\u043f\\u0456\\u0434\\u0442\\u0440\\u0438\\u043c\\u043a\\u0430) \\u0442\\u0430 \\xa0 \\u0440\\u0435\\u0437\\u0443\\u043b\\u044c\\u0442\\u0430\\u0442\\u0438 \\xa0 (\\u043f\\u0443\\u0431\\u043b\\u0456\\u043a\\u0430\\u0446\\u0456\\u0457, \\u0446\\u0438\\u0442\\u043e\\u0432\\u0430\\u043d\\u0456\\u0441\\u0442\\u044c, \\u0440\\u0435\\u043f\\u0443\\u0442\\u0430\\u0446\\u0456\\u044f). \\u0414\\u0430\\u043d\\u0456 \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u044e\\u0442\\u044c:\n\\n \\n 157 \\u043c\\u043b\\u043d \\u0446\\u0438\\u0442\\u0443\\u0432\\u0430\\u043d\\u044c; \\n 18 \\u043c\\u043b\\u043d \\u043d\\u0430\\u0443\\u043a\\u043e\\u0432\\u0438\\u0445 \\u043f\\u0443\\u0431\\u043b\\u0456\\u043a\\u0430\\u0446\\u0456\\u0439; \\n \\u0432\\u0456\\u0434\\u043f\\u043e\\u0432\\u0456\\u0434\\u0456 \\u043f\\u043e\\u043d\\u0430\\u0434 20 000 \\u0432\\u0447\\u0435\\u043d\\u0438\\u0445 \\u0437\\u0456 \\u0441\\u0432\\u0456\\u0442\\u0443. \\n \\n\\n",
